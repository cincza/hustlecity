{
  "expo": {
    "name": "Hustle City",
    "slug": "hustle-city-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/app-icon.png",
    "splash": {
      "image": "./assets/branding/hustle-city-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#090806"
    },
    "android": {
      "package": "com.hustlecity.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon.png",
        "backgroundColor": "#090806"
      }
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "extra": {
      "eas": {
        "projectId": "6612bf24-6d0b-47ef-b698-f0ff3ac13a0b"
      }
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
