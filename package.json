{
  "name": "hustle-city-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "backend": "node backend/src/server.js",
    "start:lan": "expo start --lan --port 8090",
    "start:lan:clear": "expo start --lan --clear --port 8090",
    "start": "expo start --port 8090",
    "start:clear": "expo start --clear --port 8090",
    "start:tunnel": "expo start --tunnel --port 8090",
    "android": "expo start --port 8090 --android",
    "android:lan": "expo start --lan --port 8090 --android",
    "android:tunnel": "expo start --tunnel --port 8090 --android",
    "ios": "expo start --port 8090 --ios",
    "ios:lan": "expo start --lan --port 8090 --ios",
    "ios:tunnel": "expo start --tunnel --port 8090 --ios",
    "web": "expo start --web --port 8090",
    "doctor": "npx expo-doctor",
    "check": "node --check App.js && node --check backend/src/server.js",
    "smoke": "node tools/smoke-test.mjs"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "expo": "^54.0.33",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "babel-preset-expo": "~54.0.10"
  }
}
